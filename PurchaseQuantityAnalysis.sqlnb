cells:
  - kind: 2
    value: |-
      SELECT DISTINCT RETAILSALESFACTTABLE.CUSTOMERKEY,CUSTOMER_DIMENSION.CUSTOMERNAME, RETAILSALESFACTTABLE.QUANTITY
      FROM RETAILSALESFACTTABLE
      INNER JOIN CUSTOMER_DIMENSION ON CUSTOMER_DIMENSION.CUSTOMERKEY = RETAILSALESFACTTABLE.CUSTOMERKEY
      GROUP BY RETAILSALESFACTTABLE.CUSTOMERKEY,CUSTOMER_DIMENSION.CUSTOMERNAME,RETAILSALESFACTTABLE.QUANTITY
    languageId: oracle-sql
